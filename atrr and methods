class Student():
   def_init_(self,name,marks):
      self.name = name
      self.marks = marks
   def average(self):
       sum = 0
       for val in self.marks:
           sum+=val
   print('hi',self.name,'your avg. is :', sum/3)
      
s1 = Student('karan',[97,87,98])
s1.average()
s2 = Student('loko',[87,77,99])
s2.average()
s3 = Student('bing',99,70,100)
s3.average()

